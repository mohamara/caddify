# ایمیل برای Let's Encrypt (اعلان انقضای گواهی)
ACME_EMAIL=admin@example.com

# داشبورد وب — http://SERVER_IP:9090
DASHBOARD_PASSWORD=changeme
DASHBOARD_PORT=9090
DASHBOARD_SECRET=change-this-secret

# Logging — DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Optional: archive logs → S3 / MinIO / any S3-compatible API
LOG_S3_ENABLED=0
# LOG_S3_ENDPOINT=https://s3.amazonaws.com
# LOG_S3_ENDPOINT=http://127.0.0.1:9000
# LOG_S3_BUCKET=caddify-logs
# LOG_S3_ACCESS_KEY=
# LOG_S3_SECRET_KEY=
# LOG_S3_REGION=us-east-1
# LOG_S3_PREFIX=caddify/logs
# LOG_S3_INTERVAL=3600
# LOG_S3_KEEP_LOCAL=1

# MCP (optional) — HTTP transport: ./bin/mcp --http
# CADDIFY_MCP_TOKEN=change-me-long-random
# CADDIFY_MCP_HOST=127.0.0.1
# CADDIFY_MCP_PORT=9100
# CADDIFY_MCP_DISABLE_DNS_PROTECTION=0
