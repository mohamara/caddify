#!/usr/bin/env bash
# caddify CLI — setup, add/remove domains, SSL reverse proxy
set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd)"
ROUTES="$ROOT/routes.conf"
COMPOSE_FILE="$ROOT/docker-compose.yml"
CADDYFILE="$ROOT/caddy/Caddyfile"
CERTS_DIR="$ROOT/certs"
LOGS_DIR="$ROOT/logs"
ENV_FILE="$ROOT/.env"
ENV_EXAMPLE="$ROOT/.env.example"
DEFAULT_HOST="host.docker.internal"
# Paths seen inside the Caddy container
CERTS_CONTAINER="/certs"
CADDY_LOG_DIR="/var/log/caddy"

# ── helpers ──────────────────────────────────────────────────────────

die() { echo "error: $*" >&2; exit 1; }
info() { echo "$*"; }

need_docker() {
  command -v docker >/dev/null 2>&1 || die "docker not found — install Docker first"
  docker compose version >/dev/null 2>&1 || die "docker compose not found"
}

load_env() {
  if [[ -f "$ENV_FILE" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "$ENV_FILE"
    set +a
  fi
  ACME_EMAIL="${ACME_EMAIL:-admin@example.com}"
}

trim() {
  local s="$1"
  s="${s#"${s%%[![:space:]]*}"}"
  s="${s%"${s##*[![:space:]]}"}"
  printf '%s' "$s"
}

ensure_routes_file() {
  if [[ ! -f "$ROUTES" ]]; then
    cat >"$ROUTES" <<'EOF'
# domain  port  [host]  [ssl|nossl|manual]
# example: app.example.com  3000
# example: local.test       8080  nossl
# example: secure.example.com  4430  manual
#   (manual expects certs/<domain>/fullchain.pem + privkey.pem)
EOF
  fi
}

ensure_certs_dir() {
  mkdir -p "$CERTS_DIR"
}

ensure_logs_dir() {
  mkdir -p "$LOGS_DIR/caddy/access" "$LOGS_DIR/app" "$LOGS_DIR/archive"
}

# Map LOG_LEVEL → Caddy log level
caddy_log_level() {
  case "${LOG_LEVEL:-INFO}" in
    DEBUG|debug) echo DEBUG ;;
    WARN|WARNING|warn|warning) echo WARN ;;
    ERROR|CRITICAL|error|critical) echo ERROR ;;
    *) echo INFO ;;
  esac
}

# Normalize route access-log token → off|debug|info|warn|error
normalize_route_log() {
  case "${1,,}" in
    ""|info|log|log=info|log=true|log=1) echo info ;;
    off|nolog|log=off|log=false|log=0|log=no|false) echo off ;;
    debug|log=debug) echo debug ;;
    warn|warning|log=warn|log=warning) echo warn ;;
    error|log=error) echo error ;;
    *) echo info ;;
  esac
}

caddy_access_level() {
  case "$1" in
    debug) echo DEBUG ;;
    warn) echo WARN ;;
    error) echo ERROR ;;
    *) echo INFO ;;
  esac
}

# Emit site access-log block (or nothing when off)
emit_access_log() {
  local domain="$1" level="$2"
  [[ "$level" == "off" ]] && return 0
  local clevel
  clevel="$(caddy_access_level "$level")"
  printf '\tlog {\n'
  printf '\t\toutput file %s/access/%s.log {\n' "$CADDY_LOG_DIR" "$domain"
  printf '\t\t\troll_size 50mb\n'
  printf '\t\t\troll_keep 10\n'
  printf '\t\t}\n'
  printf '\t\tformat json\n'
  printf '\t\tlevel %s\n' "$clevel"
  printf '\t}\n'
}

caddy_running() {
  docker compose -f "$COMPOSE_FILE" ps --status running 2>/dev/null | grep -qE 'caddy|caddify'
}

is_ssl_off_token() {
  case "${1,,}" in
    nossl|http|no-ssl|ssl=false|ssl=0|false|off) return 0 ;;
    *) return 1 ;;
  esac
}

is_ssl_on_token() {
  case "${1,,}" in
    ssl|https|ssl=true|ssl=1|true|auto) return 0 ;;
    *) return 1 ;;
  esac
}

is_ssl_manual_token() {
  case "${1,,}" in
    manual|custom|cert|tls-manual) return 0 ;;
    *) return 1 ;;
  esac
}

# Host paths for a domain's manual cert pair
cert_fullchain_host() { printf '%s/%s/fullchain.pem' "$CERTS_DIR" "$1"; }
cert_privkey_host() { printf '%s/%s/privkey.pem' "$CERTS_DIR" "$1"; }
cert_fullchain_caddy() { printf '%s/%s/fullchain.pem' "$CERTS_CONTAINER" "$1"; }
cert_privkey_caddy() { printf '%s/%s/privkey.pem' "$CERTS_CONTAINER" "$1"; }

has_manual_certs() {
  local domain="$1"
  [[ -f "$(cert_fullchain_host "$domain")" && -f "$(cert_privkey_host "$domain")" ]]
}

install_manual_certs() {
  local domain="$1" cert_src="$2" key_src="$3"
  local dest_dir="$CERTS_DIR/$domain"
  [[ -f "$cert_src" ]] || die "certificate file not found: $cert_src"
  [[ -f "$key_src" ]] || die "private key file not found: $key_src"
  ensure_certs_dir
  mkdir -p "$dest_dir"
  cp -f "$cert_src" "$dest_dir/fullchain.pem"
  cp -f "$key_src" "$dest_dir/privkey.pem"
  chmod 644 "$dest_dir/fullchain.pem"
  chmod 600 "$dest_dir/privkey.pem"
  info "installed manual certs for $domain → certs/$domain/"
}

require_manual_certs() {
  local domain="$1"
  has_manual_certs "$domain" || die \
    "manual SSL for $domain needs certs/$domain/fullchain.pem and privkey.pem — use: ./proxy cert $domain --cert <file> --key <file>"
}

# Write one route line: domain port [host] [nossl|manual] [log=…]
# mode: auto | off | manual ; loglevel: off|debug|info|warn|error
format_route_line() {
  local domain="$1" port="$2" host="$3" mode="$4" loglevel="${5:-info}"
  loglevel="$(normalize_route_log "$loglevel")"
  if [[ "$host" == "$DEFAULT_HOST" ]]; then
    case "$mode" in
      auto) printf '%s  %s' "$domain" "$port" ;;
      off) printf '%s  %s  nossl' "$domain" "$port" ;;
      manual) printf '%s  %s  manual' "$domain" "$port" ;;
      *) die "invalid ssl mode: $mode" ;;
    esac
  else
    case "$mode" in
      auto) printf '%s  %s  %s' "$domain" "$port" "$host" ;;
      off) printf '%s  %s  %s  nossl' "$domain" "$port" "$host" ;;
      manual) printf '%s  %s  %s  manual' "$domain" "$port" "$host" ;;
      *) die "invalid ssl mode: $mode" ;;
    esac
  fi
  if [[ "$loglevel" != "info" ]]; then
    printf '  log=%s' "$loglevel"
  fi
  printf '\n'
}

# Parse active routes into DOMAIN|PORT|HOST|MODE|LOG (auto|off|manual / off|debug|info|warn|error)
list_routes_raw() {
  ensure_routes_file
  while IFS= read -r raw || [[ -n "$raw" ]]; do
    local line domain port host mode=auto loglevel=info token
    line="${raw%%#*}"
    line="$(trim "$line")"
    [[ -z "$line" ]] && continue
    # shellcheck disable=SC2086
    set -- $line
    domain="${1:-}"
    port="${2:-}"
    host="$DEFAULT_HOST"
    mode=auto
    loglevel=info
    [[ -z "$domain" || -z "$port" ]] && continue
    shift 2 || true
    for token in "$@"; do
      case "${token,,}" in
        nolog|log=off|log=false|log=0|log=no|log=debug|log=info|log=warn|log=warning|log=error|log)
          loglevel="$(normalize_route_log "$token")"
          ;;
        *)
          if is_ssl_off_token "$token"; then
            mode=off
          elif is_ssl_manual_token "$token"; then
            mode=manual
          elif is_ssl_on_token "$token"; then
            mode=auto
          else
            host="$token"
          fi
          ;;
      esac
    done
    printf '%s|%s|%s|%s|%s\n' "$domain" "$port" "$host" "$mode" "$loglevel"
  done <"$ROUTES"
}

domain_exists() {
  list_routes_raw | awk -F'|' -v d="$1" '
    $1 == d { found = 1 }
    END { exit !found }
  '
}

validate_domain() {
  local d="$1"
  [[ "$d" =~ ^[a-zA-Z0-9]([a-zA-Z0-9.-]*[a-zA-Z0-9])?$ ]] || die "invalid domain: $d"
}

validate_port() {
  local p="$1"
  [[ "$p" =~ ^[0-9]+$ ]] || die "invalid port: $p"
  (( p >= 1 && p <= 65535 )) || die "port out of range: $p"
}

# Parse args after command: domain port [host] [--no-ssl|--ssl|--manual] [--log L] [--cert f] [--key f]
# Sets: PARSE_DOMAIN PARSE_PORT PARSE_HOST PARSE_MODE PARSE_HOST_SET PARSE_MODE_SET
#        PARSE_CERT PARSE_KEY PARSE_CERT_SET PARSE_LOG PARSE_LOG_SET
parse_route_args() {
  PARSE_DOMAIN=""
  PARSE_PORT=""
  PARSE_HOST="$DEFAULT_HOST"
  PARSE_MODE=auto
  PARSE_HOST_SET=0
  PARSE_MODE_SET=0
  PARSE_CERT=""
  PARSE_KEY=""
  PARSE_CERT_SET=0
  PARSE_LOG=info
  PARSE_LOG_SET=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --no-ssl|nossl)
        PARSE_MODE=off
        PARSE_MODE_SET=1
        shift
        ;;
      --ssl|ssl)
        PARSE_MODE=auto
        PARSE_MODE_SET=1
        shift
        ;;
      --manual|manual)
        PARSE_MODE=manual
        PARSE_MODE_SET=1
        shift
        ;;
      --no-log|--nolog)
        PARSE_LOG=off
        PARSE_LOG_SET=1
        shift
        ;;
      --log)
        [[ $# -ge 2 ]] || die "--log requires off|debug|info|warn|error"
        PARSE_LOG="$(normalize_route_log "$2")"
        PARSE_LOG_SET=1
        shift 2
        ;;
      --cert)
        [[ $# -ge 2 ]] || die "--cert requires a file path"
        PARSE_CERT="$2"
        PARSE_CERT_SET=1
        PARSE_MODE=manual
        PARSE_MODE_SET=1
        shift 2
        ;;
      --key)
        [[ $# -ge 2 ]] || die "--key requires a file path"
        PARSE_KEY="$2"
        PARSE_CERT_SET=1
        PARSE_MODE=manual
        PARSE_MODE_SET=1
        shift 2
        ;;
      -*)
        die "unknown flag: $1"
        ;;
      *)
        if [[ -z "$PARSE_DOMAIN" ]]; then
          PARSE_DOMAIN="$1"
        elif [[ -z "$PARSE_PORT" ]]; then
          PARSE_PORT="$1"
        else
          PARSE_HOST="$1"
          PARSE_HOST_SET=1
        fi
        shift
        ;;
    esac
  done

  if [[ "$PARSE_CERT_SET" == "1" ]]; then
    [[ -n "$PARSE_CERT" && -n "$PARSE_KEY" ]] || die "--cert and --key must both be provided"
  fi
}

ssl_label() {
  case "$1" in
    auto) echo "SSL auto (Let's Encrypt)" ;;
    off) echo "SSL off / HTTP only" ;;
    manual) echo "SSL manual cert" ;;
    *) echo "SSL $1" ;;
  esac
}

# ── core: generate + reload ──────────────────────────────────────────

cmd_apply() {
  load_env
  ensure_routes_file
  ensure_certs_dir
  ensure_logs_dir
  mkdir -p "$ROOT/caddy"

  local count=0
  local caddy_level
  caddy_level="$(caddy_log_level)"
  {
    printf '%s\n' '{'
    printf '\temail %s\n' "$ACME_EMAIL"
    printf '\tlog {\n'
    printf '\t\toutput file %s/error.log {\n' "$CADDY_LOG_DIR"
    printf '\t\t\troll_size 20mb\n'
    printf '\t\t\troll_keep 5\n'
    printf '\t\t}\n'
    printf '\t\tformat json\n'
    printf '\t\tlevel %s\n' "$caddy_level"
    printf '\t}\n'
    printf '%s\n\n' '}'

    while IFS='|' read -r domain port host mode loglevel; do
      [[ -z "${domain:-}" ]] && continue
      loglevel="${loglevel:-info}"
      case "$mode" in
        off)
          printf 'http://%s {\n' "$domain"
          ;;
        manual)
          require_manual_certs "$domain"
          printf '%s {\n' "$domain"
          printf '\ttls %s %s\n' "$(cert_fullchain_caddy "$domain")" "$(cert_privkey_caddy "$domain")"
          ;;
        *)
          printf '%s {\n' "$domain"
          ;;
      esac
      emit_access_log "$domain" "$loglevel"
      printf '\treverse_proxy %s:%s\n' "$host" "$port"
      printf '}\n\n'
      count=$((count + 1))
    done < <(list_routes_raw)

    if [[ "$count" -eq 0 ]]; then
      printf '%s\n' ':80 {'
      emit_access_log "_default" "info"
      printf '\trespond "caddify ready — use: ./proxy add <domain> <port>" 200\n'
      printf '}\n\n'
    fi
  } >"$CADDYFILE"

  info "Caddyfile updated ($count route(s), log level $caddy_level)"

  if caddy_running; then
    docker compose -f "$COMPOSE_FILE" exec -T caddy \
      caddy reload --config /etc/caddy/Caddyfile
    info "reloaded"
  fi
}

# ── commands ─────────────────────────────────────────────────────────

cmd_setup() {
  need_docker
  local email="${1:-}"

  if [[ ! -f "$ENV_FILE" ]]; then
    cp "$ENV_EXAMPLE" "$ENV_FILE"
  fi

  if [[ -n "$email" ]]; then
    if grep -q '^ACME_EMAIL=' "$ENV_FILE"; then
      sed -i "s|^ACME_EMAIL=.*|ACME_EMAIL=$email|" "$ENV_FILE"
    else
      echo "ACME_EMAIL=$email" >>"$ENV_FILE"
    fi
    info "ACME_EMAIL=$email"
  else
    load_env
    if [[ "$ACME_EMAIL" == "admin@example.com" ]]; then
      echo
      read -r -p "Let's Encrypt email: " email
      [[ -n "$email" ]] || die "email required"
      sed -i "s|^ACME_EMAIL=.*|ACME_EMAIL=$email|" "$ENV_FILE"
      info "ACME_EMAIL=$email"
    fi
  fi

  ensure_routes_file
  ensure_certs_dir
  ensure_logs_dir
  cmd_apply
  docker compose -f "$COMPOSE_FILE" up -d --build
  load_env
  local dash_port="${DASHBOARD_PORT:-9090}"
  echo
  info "✓ proxy is up on :80 / :443"
  info "✓ dashboard: http://SERVER_IP:${dash_port}  (password in .env)"
  info "✓ logs: $LOGS_DIR  (./proxy logs)"
  echo
  info "next:"
  info "  1) change DASHBOARD_PASSWORD in .env"
  info "  2) point domain DNS to this server"
  info "  3) add routes in the dashboard or: ./proxy add app.example.com 3000"
  if [[ "${LOG_S3_ENABLED:-0}" =~ ^(1|true|yes|on)$ ]]; then
    info "  4) S3 log upload is enabled (LOG_S3_*)"
  fi
}

cmd_up() {
  need_docker
  [[ -f "$ENV_FILE" ]] || die "not set up — run: ./proxy setup"
  cmd_apply
  docker compose -f "$COMPOSE_FILE" up -d --build
  info "started"
  load_env
  info "dashboard: http://127.0.0.1:${DASHBOARD_PORT:-9090}"
}

cmd_down() {
  need_docker
  docker compose -f "$COMPOSE_FILE" down
  info "stopped"
}

cmd_restart() {
  need_docker
  docker compose -f "$COMPOSE_FILE" restart
  info "restarted"
}

cmd_add() {
  parse_route_args "$@"
  local domain="$PARSE_DOMAIN" port="$PARSE_PORT" host="$PARSE_HOST" mode="$PARSE_MODE" loglevel="$PARSE_LOG"
  [[ -n "$domain" && -n "$port" ]] || die "usage: ./proxy add <domain> <port> [host] [--ssl|--no-ssl|--manual] [--log L] [--cert f --key f]"

  validate_domain "$domain"
  validate_port "$port"
  ensure_routes_file
  ensure_certs_dir

  if domain_exists "$domain"; then
    die "domain already exists: $domain (use: ./proxy set $domain $port)"
  fi

  if [[ "$PARSE_CERT_SET" == "1" ]]; then
    install_manual_certs "$domain" "$PARSE_CERT" "$PARSE_KEY"
    mode=manual
  fi
  if [[ "$mode" == "manual" ]]; then
    require_manual_certs "$domain"
  fi

  format_route_line "$domain" "$port" "$host" "$mode" "$loglevel" >>"$ROUTES"

  info "added $domain → ${host}:${port} ($(ssl_label "$mode"), log=$loglevel)"
  cmd_apply
}

cmd_set() {
  parse_route_args "$@"
  local domain="$PARSE_DOMAIN" port="$PARSE_PORT" host="$PARSE_HOST" mode="$PARSE_MODE" loglevel="$PARSE_LOG"
  local host_set="$PARSE_HOST_SET"
  local mode_set="$PARSE_MODE_SET"
  local log_set="$PARSE_LOG_SET"

  [[ -n "$domain" && -n "$port" ]] || die "usage: ./proxy set <domain> <port> [host] [--ssl|--no-ssl|--manual] [--log L] [--cert f --key f]"

  validate_domain "$domain"
  validate_port "$port"
  domain_exists "$domain" || die "domain not found: $domain"

  local cur_host cur_mode cur_log
  cur_host="$(list_routes_raw | awk -F'|' -v d="$domain" '$1 == d { print $3 }')"
  cur_mode="$(list_routes_raw | awk -F'|' -v d="$domain" '$1 == d { print $4 }')"
  cur_log="$(list_routes_raw | awk -F'|' -v d="$domain" '$1 == d { print $5 }')"
  cur_host="${cur_host:-$DEFAULT_HOST}"
  cur_mode="${cur_mode:-auto}"
  cur_log="${cur_log:-info}"

  [[ "$host_set" == "1" ]] || host="$cur_host"
  [[ "$mode_set" == "1" ]] || mode="$cur_mode"
  [[ "$log_set" == "1" ]] || loglevel="$cur_log"

  if [[ "$PARSE_CERT_SET" == "1" ]]; then
    install_manual_certs "$domain" "$PARSE_CERT" "$PARSE_KEY"
    mode=manual
  fi
  if [[ "$mode" == "manual" ]]; then
    require_manual_certs "$domain"
  fi

  local tmp
  tmp="$(mktemp)"
  while IFS= read -r raw || [[ -n "$raw" ]]; do
    local line d
    line="${raw%%#*}"
    line="$(trim "$line")"
    if [[ -n "$line" ]]; then
      # shellcheck disable=SC2086
      set -- $line
      d="${1:-}"
      if [[ "$d" == "$domain" ]]; then
        format_route_line "$domain" "$port" "$host" "$mode" "$loglevel"
        continue
      fi
    fi
    printf '%s\n' "$raw"
  done <"$ROUTES" >"$tmp"
  mv "$tmp" "$ROUTES"

  info "updated $domain → ${host}:${port} ($(ssl_label "$mode"), log=$loglevel)"
  cmd_apply
}

cmd_cert() {
  local domain="" cert="" key=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --cert)
        [[ $# -ge 2 ]] || die "--cert requires a file path"
        cert="$2"
        shift 2
        ;;
      --key)
        [[ $# -ge 2 ]] || die "--key requires a file path"
        key="$2"
        shift 2
        ;;
      -*)
        die "unknown flag: $1"
        ;;
      *)
        if [[ -z "$domain" ]]; then
          domain="$1"
        else
          die "unexpected argument: $1"
        fi
        shift
        ;;
    esac
  done

  [[ -n "$domain" && -n "$cert" && -n "$key" ]] || \
    die "usage: ./proxy cert <domain> --cert <fullchain.pem> --key <privkey.pem>"

  validate_domain "$domain"
  domain_exists "$domain" || die "domain not found: $domain — add it first with ./proxy add"

  install_manual_certs "$domain" "$cert" "$key"

  local cur_port cur_host cur_log
  cur_port="$(list_routes_raw | awk -F'|' -v d="$domain" '$1 == d { print $2 }')"
  cur_host="$(list_routes_raw | awk -F'|' -v d="$domain" '$1 == d { print $3 }')"
  cur_log="$(list_routes_raw | awk -F'|' -v d="$domain" '$1 == d { print $5 }')"
  cur_host="${cur_host:-$DEFAULT_HOST}"
  cur_log="${cur_log:-info}"

  local tmp
  tmp="$(mktemp)"
  while IFS= read -r raw || [[ -n "$raw" ]]; do
    local line d
    line="${raw%%#*}"
    line="$(trim "$line")"
    if [[ -n "$line" ]]; then
      # shellcheck disable=SC2086
      set -- $line
      d="${1:-}"
      if [[ "$d" == "$domain" ]]; then
        format_route_line "$domain" "$cur_port" "$cur_host" "manual" "$cur_log"
        continue
      fi
    fi
    printf '%s\n' "$raw"
  done <"$ROUTES" >"$tmp"
  mv "$tmp" "$ROUTES"

  info "SSL mode for $domain → manual"
  cmd_apply
}

cmd_rm() {
  local domain="${1:-}"
  [[ -n "$domain" ]] || die "usage: ./proxy rm <domain>"

  domain_exists "$domain" || die "domain not found: $domain"

  local tmp
  tmp="$(mktemp)"
  while IFS= read -r raw || [[ -n "$raw" ]]; do
    local line d
    line="${raw%%#*}"
    line="$(trim "$line")"
    if [[ -n "$line" ]]; then
      # shellcheck disable=SC2086
      set -- $line
      d="${1:-}"
      [[ "$d" == "$domain" ]] && continue
    fi
    printf '%s\n' "$raw"
  done <"$ROUTES" >"$tmp"
  mv "$tmp" "$ROUTES"

  info "removed $domain"
  cmd_apply
}

cmd_list() {
  ensure_routes_file
  local n=0
  printf '%-32s %-8s %-16s %-10s %s\n' "DOMAIN" "PORT" "HOST" "SSL" "LOG"
  printf '%-32s %-8s %-16s %-10s %s\n' "------" "----" "----" "---" "---"
  while IFS='|' read -r domain port host mode loglevel; do
    [[ -z "${domain:-}" ]] && continue
    local show_host="$host" show_ssl="$mode"
    [[ "$host" == "$DEFAULT_HOST" ]] && show_host="localhost"
    case "$mode" in
      auto) show_ssl="auto" ;;
      off) show_ssl="off" ;;
      manual) show_ssl="manual" ;;
    esac
    printf '%-32s %-8s %-16s %-10s %s\n' "$domain" "$port" "$show_host" "$show_ssl" "${loglevel:-info}"
    n=$((n + 1))
  done < <(list_routes_raw)

  if [[ "$n" -eq 0 ]]; then
    echo "(no routes — ./proxy add <domain> <port>)"
  else
    echo
    info "$n route(s)"
  fi
}

cmd_status() {
  need_docker
  echo "=== container ==="
  if [[ -f "$ENV_FILE" ]]; then
    docker compose -f "$COMPOSE_FILE" ps
  else
    echo "not set up — run: ./proxy setup"
    return
  fi
  echo
  echo "=== routes ==="
  cmd_list
  echo
  load_env
  echo "=== config ==="
  echo "email:      $ACME_EMAIL"
  echo "certs:      $CERTS_DIR"
  echo "logs:       $LOGS_DIR"
  echo "log_level:  ${LOG_LEVEL:-INFO}"
  echo "log_s3:     ${LOG_S3_ENABLED:-0}"
  echo "dashboard:  http://127.0.0.1:${DASHBOARD_PORT:-9090}"
  echo "root:       $ROOT"
}

cmd_logs() {
  load_env
  ensure_logs_dir
  local sub="${1:-}"

  case "$sub" in
    upload)
      need_docker
      info "archiving logs and uploading to S3…"
      docker compose -f "$COMPOSE_FILE" run --rm --no-deps log-shipper \
        python -u ship.py --once --force
      ;;
    access)
      local dir="$LOGS_DIR/caddy/access"
      mkdir -p "$dir"
      shopt -s nullglob
      local files=("$dir"/*.log)
      shopt -u nullglob
      if [[ ${#files[@]} -eq 0 ]]; then
        # legacy single file
        local f="$LOGS_DIR/caddy/access.log"
        [[ -f "$f" ]] || die "no access log yet under $dir"
        tail -n "${2:-100}" -F "$f"
      else
        tail -n "${2:-100}" -F "${files[@]}"
      fi
      ;;
    error)
      local f="$LOGS_DIR/caddy/error.log"
      [[ -f "$f" ]] || die "no error log yet: $f"
      tail -n "${2:-100}" -F "$f"
      ;;
    app|audit)
      local name="caddify.log"
      [[ "$sub" == "audit" ]] && name="audit.log"
      local f="$LOGS_DIR/app/$name"
      [[ -f "$f" ]] || die "no $sub log yet: $f"
      tail -n "${2:-100}" -F "$f"
      ;;
    follow|"")
      need_docker
      # Prefer file tails when present; also show container stdout
      if [[ -f "$LOGS_DIR/caddy/access.log" || -f "$LOGS_DIR/app/caddify.log" ]]; then
        info "following logs/ (Ctrl+C to stop) — layers: access|error|app|audit|upload"
        tail -n 50 -F \
          "$LOGS_DIR/caddy/access.log" \
          "$LOGS_DIR/caddy/error.log" \
          "$LOGS_DIR/app/caddify.log" \
          "$LOGS_DIR/app/audit.log" \
          2>/dev/null
      else
        docker compose -f "$COMPOSE_FILE" logs -f --tail=100 caddy dashboard
      fi
      ;;
    help|-h|--help)
      cat <<'EOF'
Usage: ./proxy logs [access|error|app|audit|upload|follow]
  (default)   follow local log files / container logs
  access      Caddy access JSON
  error       Caddy error JSON
  app         dashboard/app layer
  audit       audit layer
  upload      archive now and push to S3 (needs LOG_S3_*)
EOF
      ;;
    *)
      die "unknown logs target: $sub — try: ./proxy logs help"
      ;;
  esac
}

cmd_email() {
  local email="${1:-}"
  [[ -n "$email" ]] || die "usage: ./proxy email <address>"
  [[ -f "$ENV_FILE" ]] || cp "$ENV_EXAMPLE" "$ENV_FILE"
  if grep -q '^ACME_EMAIL=' "$ENV_FILE"; then
    sed -i "s|^ACME_EMAIL=.*|ACME_EMAIL=$email|" "$ENV_FILE"
  else
    echo "ACME_EMAIL=$email" >>"$ENV_FILE"
  fi
  info "ACME_EMAIL=$email"
  if caddy_running; then
    cmd_apply
    docker compose -f "$COMPOSE_FILE" up -d
  fi
}

cmd_help() {
  cat <<'EOF'
caddify — دامنه → پورت با SSL انتخابی

Usage:
  ./proxy setup [email]          نصب و روشن کردن پراکسی + داشبورد
  ./proxy add <domain> <port> [host] [--ssl|--no-ssl|--manual] [--log L] [--cert f --key f]
  ./proxy set <domain> <port> [host] [--ssl|--no-ssl|--manual] [--log L] [--cert f --key f]
  ./proxy cert <domain> --cert <fullchain.pem> --key <privkey.pem>
  ./proxy rm  <domain>           حذف دامنه
  ./proxy list                   لیست دامنه‌ها
  ./proxy status                 وضعیت سرویس + مسیرها
  ./proxy logs [layer|upload]    لاگ زنده / آپلود S3
  ./proxy apply                  بازسازی کانفیگ و ریلود
  ./proxy up | down | restart    کنترل کانتینر
  ./proxy email <address>        ایمیل Let's Encrypt
  ./proxy help                   همین راهنما

SSL:
  --ssl              گواهی خودکار Let's Encrypt (پیش‌فرض)
  --no-ssl           فقط HTTP — بدون گواهی
  --manual           گواهی دستی از certs/<domain>/
  --cert f --key f   نصب گواهی دستی و فعال‌سازی حالت manual
  --log L            سطح لاگ دسترسی دامنه: off|debug|info|warn|error (پیش‌فرض info)
  --no-log           معادل --log off

Logging:
  LOG_LEVEL          DEBUG|INFO|WARNING|ERROR
  ./proxy logs       follow all layers
  ./proxy logs access|error|app|audit
  ./proxy logs upload   → S3 (LOG_S3_ENABLED + credentials)

Dashboard:
  http://SERVER_IP:9090
  رمز: DASHBOARD_PASSWORD در فایل .env

Examples:
  ./proxy add app.example.com 3000
  ./proxy add api.example.com 8080 --ssl
  ./proxy add local.test 9000 --no-ssl
  ./proxy add secure.example.com 4430 --cert ./fullchain.pem --key ./privkey.pem
  ./proxy cert app.example.com --cert ./fullchain.pem --key ./privkey.pem
  ./proxy set app.example.com 3001 --ssl
  ./proxy set app.example.com 3001 --log debug
  ./proxy logs audit
  ./proxy logs upload
  ./proxy rm  api.example.com

Notes:
  • برای SSL خودکار: DNS دامنه باید به IP این سرور اشاره کند
  • پورت‌های 80 و 443 باید باز باشند
  • گواهی دستی در certs/<domain>/fullchain.pem و privkey.pem ذخیره می‌شود
  • لاگ‌ها در logs/ — لایه‌ها: access (per-domain), error, app, audit
  • لاگ دسترسی هر دامنه: logs/caddy/access/<domain>.log
EOF
}

# ── dispatch ─────────────────────────────────────────────────────────

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    setup|init)   cmd_setup "$@" ;;
    up|start)     cmd_up "$@" ;;
    down|stop)    cmd_down "$@" ;;
    restart)      cmd_restart "$@" ;;
    add)          cmd_add "$@" ;;
    set|update)   cmd_set "$@" ;;
    cert|tls)     cmd_cert "$@" ;;
    rm|remove|del|delete) cmd_rm "$@" ;;
    list|ls)      cmd_list "$@" ;;
    status|ps)    cmd_status "$@" ;;
    logs|log)     cmd_logs "$@" ;;
    apply|reload) cmd_apply "$@" ;;
    email)        cmd_email "$@" ;;
    help|-h|--help) cmd_help ;;
    *)
      die "unknown command: $cmd — try: ./proxy help"
      ;;
  esac
}

main "$@"
